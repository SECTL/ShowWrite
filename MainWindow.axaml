1-14.7,43.1-20.4,67.9-19.8c9.3,0.2,18.8,0.4,27.9-1.1c29.4-4.9,52.8-20.5,71.8-42.9c8.1-9.5,15.2-19.7,22.7-29.6C2074.9,295.2,2077.7,291.3,2081.6,286.1L2081.6,286.1z M1920,110.2c34,13.5,61,34.4,71.8,70.3c12.1,40.2,6.8,77.9-23.8,108.6c-11.4,11.5-25.2,21.1-39.2,29.6c-20.2,12.3-43.3,17.7-66.6,23.8c33.8-28.6,57.1-63.7,68.8-106.2C1942.9,193.1,1940.8,151.1,1920,110.2L1920,110.2z M1805.2,344.4c-35-10.9-67.6-21.1-94.9-43.1c-41.4-33.4-53.6-88.2-30.4-135.9c11.5-23.7,38.9-47,65.5-55.5C1706.8,201.9,1734.3,277.1,1805.2,344.4L1805.2,344.4z"/>
                    </Canvas>

                    <Canvas x:Name="ElemGeo" Width="50" Height="50">
                        <Path x:Name="GeoFill" Width="50" Height="50"
                              Fill="#FFB23B"
                              Stretch="Uniform"
                              Data="M2439.1,946.8c-12.7,24.2-29.9,45.4-49.7,66.7c-39.3-112.8-107.6-205.5-184.7-294.1c-43.4,50.5-87.9,98.6-106.1,163.6c0.7,0.6,1.5,1.3,2.2,1.9c34.3-28.7,68.6-57.5,103.9-87c40.1,37.9,72.9,80.5,98.5,130.4c-24.8,28.1-54.5,49.9-84.9,73.1c-6.6-8-12.5-15.2-16.8-20.5c16.2-17.3,31.3-33.6,46.7-49.7c9.2-9.6,9.5-9.5,3.8-21.1c-11.1-22.6-27.6-40.7-48-57.4c-7.7,4.6-15.7,8.8-22.9,13.9c-33,23.5-63.2,50.2-91.1,79.5c-2,2.1-3.8,4.2-6.1,6.9c-1.8-2-3-3-3.7-4.3c-15.4-27-27.1-55.4-34.3-85.7c-1.7-7.1-0.4-12.5,3.9-18.2c27.3-36.5,59.8-68.1,94-97.9c16.8-14.6,34.3-28.4,51.5-42.4c3.1-2.6,6.6-4.8,9.6-7C2275.7,738.9,2411,883,2439.1,946.8L2439.1,946.8z M2204.3,1197.5c-28.4-24.3-56.5-47.2-83.4-71.5c-42-37.9-81-78.8-114.4-124.6c-10.7-14.6-19.9-30.3-30.1-45.3c-4.2-6.2-4.9-11.7-0.1-17.9c13.8-17.9,27.4-36,41.2-54c0.9-1.2,2.5-2,4.5-3.7c38.7,111.6,106.9,204,182.8,291.5c34.8-22.7,101.1-123.8,106.9-164.3c-36.4,28.7-69.6,58.3-105.4,87.5c-39.9-37.5-72.6-80.2-98.5-130.4c24.6-27.9,54.5-49.6,84.8-73c6.4,7.6,12.3,14.7,17.9,21.4c-7.7,8.3-14.4,16-21.6,23.3c-9.5,9.7-19.3,19.2-29.2,28.5c-4.3,4-5.1,7.9-2.8,13.2c10.3,23.6,26.7,42.3,46.1,58.8c3.5,3,6.9,2.1,10.2,0c8-5.1,16.2-9.8,23.8-15.5c31.1-23.2,60.3-48.7,86.6-77.3c1.1-1.2,2.4-2.2,3.4-3.2c1,0.4,1.9,0.5,2.2,1c16.9,28.1,28.9,58.2,36.4,90.1c1.5,6.4-0.6,10.9-4.2,15.9c-20.9,28.3-44.9,53.8-71,77.3c-23.6,21.2-48.2,41.3-72.4,61.8C2214.3,1190.3,2210.2,1193.1,2204.3,1197.5L2204.3,1197.5z"/>
                    </Canvas>
                </StackPanel>
            </StackPanel>
            
            <TextBlock x:Name="CameraInfoText"
                       FontSize="14"
                       Foreground="#AAAAAA"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       Margin="20"
                       IsVisible="False"/>
            
            <Border x:Name="PluginOverlay"
                    Background="Transparent"
                    IsVisible="False"
                    ZIndex="500">
            </Border>
        </Grid>

        <Border x:Name="PhotoPanel"
                Width="280"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Background="{DynamicResource ThemeSurface}"
                BorderBrush="{DynamicResource ThemeSurfaceVariant}"
                BorderThickness="1,0,0,0"
                IsVisible="False"
                Margin="0,0,0,60"
                ZIndex="300">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0">
                    <ScrollViewer Padding="8">
                        <ItemsControl x:Name="PhotoList" ItemsSource="{Binding Photos}" x:CompileBindings="False">
                            <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:PhotoItem">
                                <Border x:Name="PhotoItemBorder"
                                        Background="{Binding IsSelected, Converter={StaticResource SelectedBackgroundConverter}}"
                                        CornerRadius="8" 
                                        Margin="4"
                                        Padding="8"
                                        Cursor="Hand"
                                        PointerPressed="PhotoItem_PointerPressed"
                                        Tag="{Binding}">
                                    <Grid RowDefinitions="Auto,*">
                                        <TextBlock Grid.Row="0"
                                                   Text="{Binding Index}"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding IsSelected, Converter={StaticResource SelectedForegroundConverter}}"
                                                   HorizontalAlignment="Left"
                                                   Margin="0,0,0,4"/>
                                        <Grid Grid.Row="1">
                                            <Image Source="{Binding Thumbnail}"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Stretch"/>
                                            <Border IsVisible="{Binding IsSelected}"
                                                    Background="#80000000"
                                                    VerticalAlignment="Stretch"
                                                    HorizontalAlignment="Stretch">
                                                <TextBlock Text="再次点击&#10;返回实时"
                                                           FontSize="14"
                                                           FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           TextAlignment="Center"/>
                                            </Border>
                                            <Grid HorizontalAlignment="Left"
                                                  VerticalAlignment="Bottom"
                                                  Margin="4">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <CheckBox x:Name="PhotoCheckBox"
                                                          Grid.Row="0"
                                                          HorizontalAlignment="Left"
                                                          IsChecked="{Binding IsChecked}"
                                                          IsVisible="{Binding $parent[ItemsControl].((local:MainWindow)DataContext).IsSelectMode}"
                                                          Background="White"
                                                          BorderBrush="#CCCCCC"/>
                                                <Button Width="28"
                                                        Height="28"
                                                        Grid.Row="1"
                                                        HorizontalAlignment="Left"
                                                        Classes="delete-btn"
                                                        CornerRadius="14"
                                                        Padding="0"
                                                        Click="DeletePhoto_Click"
                                                        Tag="{Binding}"
                                                        IsVisible="{Binding !IsDeleting}">
                                                    <Viewbox Width="16" Height="16">
                                                        <Path Fill="White" Data="M5.75 3V1.5h4.5V3zm-1.5 0V1a1 1 0 0 1 1-1h5.5a1 1 0 0 1 1 1v2h2.5a.75.75 0 0 1 0 1.5h-.365l-.743 9.653A2 2 0 0 1 11.148 16H4.852a2 2 0 0 1-1.994-1.847L2.115 4.5H1.75a.75.75 0 0 1 0-1.5zm-.63 1.5h8.76l-.734 9.538a.5.5 0 0 1-.498.462H4.852a.5.5 0 0 1-.498-.462z"/>
                                                    </Viewbox>
                                                </Button>
                                                <StackPanel Orientation="Horizontal"
                                                            Grid.Row="1"
                                                            HorizontalAlignment="Left"
                                                            Spacing="4"
                                                            IsVisible="{Binding IsDeleting}">
                                                    <Button Content="确认删除"
                                                            FontSize="11"
                                                            Classes="delete-btn"
                                                            Foreground="White"
                                                            CornerRadius="4"
                                                            Padding="8,4"
                                                            Click="ConfirmDeletePhoto_Click"
                                                            Tag="{Binding}"/>
                                                    <Button Content="取消"
                                                            FontSize="11"
                                                            Background="#555555"
                                                            Foreground="White"
                                                            CornerRadius="4"
                                                            Padding="8,4"
                                                            Click="CancelDeletePhoto_Click"
                                                            Tag="{Binding}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                
                <Border x:Name="ImportingOverlay"
                        Background="#E0000000"
                        IsVisible="False"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        CornerRadius="8"
                        Padding="20,12">
                    <StackPanel Orientation="Vertical" Spacing="8">
                        <ProgressBar IsIndeterminate="True"
                                     Width="120"
                                     Height="6"
                                     HorizontalAlignment="Center"/>
                        <TextBlock Text="正在导入，请等待..."
                                   FontSize="14"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
            
            <Border Grid.Row="1" 
                        Background="Transparent" 
                        Padding="12,8">
                    <StackPanel Orientation="Vertical" 
                                HorizontalAlignment="Center" 
                                Spacing="8">
                        <StackPanel x:Name="NormalButtons"
                                    Orientation="Horizontal" 
                                    HorizontalAlignment="Center" 
                                    Spacing="16">
                            <Button x:Name="SavePhotoBtn"
                                    Classes="nav-btn"
                                    Click="SavePhotoBtn_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Viewbox Width="18" Height="18">
                                        <Path Classes="icon-path" Data="M433.941 129.941l-83.882-83.882A48 48 0 0 0 316.118 32H48C21.49 32 0 53.49 0 80v352c0 26.51 21.49 48 48 48h352c26.51 0 48-21.49 48-48V163.882a48 48 0 0 0-14.059-33.941zM224 416c-35.346 0-64-28.654-64-64 0-35.346 28.654-64 64-64s64 28.654 64 64c0 35.346-28.654 64-64 64zm96-304.52V212c0 6.627-5.373 12-12 12H76c-6.627 0-12-5.373-12-12V108c0-6.627 5.373-12 12-12h228.52c3.183 0 6.235 1.264 8.485 3.515l3.48 3.48A11.996 11.996 0 0 1 320 111.48z"/>
                                    </Viewbox>
                                    <TextBlock Text="保存照片" FontSize="12" Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <Button x:Name="ImportPhotoBtn"
                                    Classes="nav-btn"
                                    Click="ImportPhotoBtn_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Viewbox Width="18" Height="18">
                                        <Path Classes="icon-path" Data="M432 320h-32a16 16 0 0 0-16 16v112H64V128h144a16 16 0 0 0 16-16V80a16 16 0 0 0-16-16H48a48 48 0 0 0-48 48v352a48 48 0 0 0 48 48h352a48 48 0 0 0 48-48V336a16 16 0 0 0-16-16zM488 0H360c-21.37 0-32.05 25.91-17 41l35.73 35.73L135 320.37a24 24 0 0 0 0 34L157.67 377a24 24 0 0 0 34 0l243.61-243.68L471 169c15 15 41 4.5 41-17V24a24 24 0 0 0-24-24z"/>
                                    </Viewbox>
                                    <TextBlock Text="导入" FontSize="12" Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        
                        <StackPanel x:Name="SelectModeButtons"
                                    Orientation="Horizontal" 
                                    HorizontalAlignment="Center" 
                                    Spacing="12"
                                    IsVisible="False">
                            <Button Classes="nav-btn"
                                    Click="ConfirmSavePhotos_Click">
                                <TextBlock Text="确定" FontSize="12" Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center"/>
                            </Button>
                            <Button Classes="nav-btn"
                                    Click="CancelSelectMode_Click">
                                <TextBlock Text="取消" FontSize="12" Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center"/>
                            </Button>
                            <Button Classes="nav-btn"
                                    Click="InvertSelection_Click">
                                <TextBlock Text="反选" FontSize="12" Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                        
                        <CheckBox x:Name="IncludeInkCheckBox"
                                  Classes="ink-checkbox"
                                  Content="保留墨迹注释"
                                  HorizontalAlignment="Center"
                                  Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Popup x:Name="MoreMenuPopup"
               PlacementMode="Top"
               IsLightDismissEnabled="True"
               IsOpen="False">
            <Border Background="{DynamicResource ThemeSurface}" CornerRadius="8" Padding="4" BorderBrush="{DynamicResource ThemeSurfaceVariant}" BorderThickness="1">
                <StackPanel>
                    <Button Content="切换摄像头" Click="SwitchCamera_Click" Classes="menu-btn" Background="Transparent" Foreground="{DynamicResource ThemeTextPrimary}" HorizontalContentAlignment="Center" Padding="20,12"/>
                    <Button Content="梯形校正" Click="KeystoneCorrection_Click" Classes="menu-btn" Background="Transparent" Foreground="{DynamicResource ThemeTextPrimary}" HorizontalContentAlignment="Center" Padding="20,12"/>
                    <Button Content="清除矫正" Click="ClearKeystone_Click" Classes="menu-btn" Background="Transparent" Foreground="{DynamicResource ThemeTextPrimary}" HorizontalContentAlignment="Center" Padding="20,12"/>
					<Button Content="随心记" Click="OpenRandomNoteWindow_Click" Classes="menu-btn" Background="Transparent" Foreground="{DynamicResource ThemeTextPrimary}" HorizontalContentAlignment="Center" Padding="20,12"/>
					<Button Content="设置" Click="OpenSettings_Click" Classes="menu-btn" Background="Transparent" Foreground="{DynamicResource ThemeTextPrimary}" HorizontalContentAlignment="Center" Padding="20,12"/>
                    <Button Content="退出" Click="Exit_Click" Classes="menu-btn" Background="Transparent" Foreground="{DynamicResource ThemeTextPrimary}" HorizontalContentAlignment="Center" Padding="20,12"/>
                </StackPanel>
            </Border>
        </Popup>

        <Border x:Name="PagePanel"
                Grid.Row="0"
                Grid.RowSpan="2"
                Width="280"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Background="{DynamicResource ThemeSurface}"
                BorderBrush="{DynamicResource ThemeSurfaceVariant}"
                BorderThickness="1,0,0,0"
                IsVisible="False"
                Margin="0,0,0,60"
                ZIndex="250">
            <Border.RenderTransform>
                <TranslateTransform X="280"/>
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0">
                    <ScrollViewer Padding="8">
                        <ItemsControl x:Name="PageList" ItemsSource="{Binding WhiteboardPageThumbnails}" x:CompileBindings="False">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:WhiteboardPageThumbnail">
                                    <Border x:Name="PageItemBorder"
                                            Background="{Binding IsSelected, Converter={StaticResource SelectedBackgroundConverter}}"
                                            CornerRadius="8" 
                                            Margin="4"
                                            Padding="8"
                                            Cursor="Hand"
                                            PointerPressed="PageItem_PointerPressed"
                                            Tag="{Binding PageNumber}">
                                        <Grid RowDefinitions="Auto,*">
                                            <TextBlock Grid.Row="0"
                                                       Text="{Binding PageNumber, StringFormat='第{0}页'}"
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       Foreground="{Binding IsSelected, Converter={StaticResource SelectedForegroundConverter}}"
                                                       HorizontalAlignment="Left"
                                                       Margin="0,0,0,4"/>
                                            <Border Grid.Row="1"
                                                    Background="#2E5C4A"
                                                    CornerRadius="4"
                                                    Height="120">
                                                <Image Source="{Binding Thumbnail}"
                                                       Stretch="Uniform"
                                                       HorizontalAlignment="Stretch"
                                                       VerticalAlignment="Stretch"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    
                    <Border x:Name="PageImportingOverlay"
                            Background="#E0000000"
                            IsVisible="False"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            CornerRadius="8"
                            Padding="20,12">
                        <StackPanel Orientation="Vertical" Spacing="8">
                            <ProgressBar IsIndeterminate="True"
                                         Width="120"
                                         Height="6"
                                         HorizontalAlignment="Center"/>
                            <TextBlock Text="正在导入PPT，请等待..."
                                       FontSize="14"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
                
                <Border Grid.Row="1" 
                        Background="Transparent" 
                        Padding="12,8">
                    <StackPanel Orientation="Vertical" 
                                HorizontalAlignment="Center" 
                                Spacing="8">
                        <Button Classes="nav-btn"
                                Click="AddPageBtn_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Viewbox Width="18" Height="18">
                                    <Path Classes="icon-path" Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
                                </Viewbox>
                                <TextBlock Text="添加新页" FontSize="12" Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        
                        <Button Classes="nav-btn"
                                Click="ImportPptBtn_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Viewbox Width="18" Height="18">
                                    <Path Classes="icon-path" Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zM7 10h2v7H7zm4-3h2v10h-2zm4 6h2v4h-2z"/>
                                </Viewbox>
                                <TextBlock Text="导入PPT" FontSize="12" Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Button x:Name="PluginCancelButton"
                Classes="tool-btn-square"
                Width="56"
                Height="56"
                IsVisible="False"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                ZIndex="300"
                Click="PluginCancelButton_Click">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Viewbox Grid.Row="0" Width="28" Height="28" HorizontalAlignment="Center">
                    <Path Classes="icon-path" Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
                </Viewbox>
                <TextBlock Grid.Row="1" Text="取消" FontSize="10" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Center" Margin="0,4,0,0" Classes="button-text-label"/>
            </Grid>
        </Button>

        <Popup x:Name="PenSettingsPopup"
               PlacementMode="Top"
               PlacementTarget="{Binding #PenBtn}"
               IsLightDismissEnabled="True"
               IsOpen="False">
            <Border Background="{DynamicResource ThemeSurface}" CornerRadius="12" Padding="12" BorderBrush="{DynamicResource ThemeSurfaceVariant}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="颜色" FontSize="13" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,2"/>
                    <Grid x:Name="ColorGrid" Width="200">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                    </Grid>
                    
                    <Border Height="1" Background="{DynamicResource ThemeSurfaceVariant}" Margin="0,4"/>
                    
                    <TextBlock Text="粗细" FontSize="13" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,2"/>
                    <StackPanel x:Name="SizePanel" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>

        <Popup x:Name="ClearSlidePopup"
               PlacementMode="Top"
               PlacementTarget="{Binding #EraserBtn}"
               IsLightDismissEnabled="True"
               IsOpen="False">
            <Border Background="{DynamicResource ThemeSurface}" CornerRadius="12" Padding="16" BorderBrush="{DynamicResource ThemeSurfaceVariant}" BorderThickness="1">
                <StackPanel Spacing="12" Width="200">
                    <TextBlock Text="滑动清屏" FontSize="13" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Center"/>
                    <Grid>
                        <Border x:Name="SlideTrack" 
                                Height="44" 
                                CornerRadius="22" 
                                Background="{DynamicResource ThemeSurfaceVariant}">
                            <TextBlock Text="→ 滑动清屏 →" 
                                       FontSize="12" 
                                       Foreground="{DynamicResource ThemeTextTertiary}" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"/>
                        </Border>
                        <Border x:Name="SlideThumb"
                                Width="44"
                                Height="44"
                                CornerRadius="22"
                                Background="#FF6B6B"
                                Cursor="Hand"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,0">
                            <Viewbox Width="20" Height="20">
                                <Path Fill="White" Data="M16.5 4.478v.227a49 49 0 0 1 3.878.512a.75.75 0 1 1-.256 1.478l-.209-.035l-1.005 13.07a3 3 0 0 1-2.991 2.77H8.084a3 3 0 0 1-2.991-2.77L4.087 6.66l-.209.035a.75.75 0 0 1-.256-1.478A49 49 0 0 1 7.5 4.705v-.227c0-1.564 1.213-2.9 2.816-2.951a53 53 0 0 1 3.369 0c1.603.051 2.815 1.387 2.815 2.951m-6.136-1.452a51 51 0 0 1 3.273 0C14.39 3.05 15 3.684 15 4.478v.113a50 50 0 0 0-6 0v-.113c0-.794.609-1.428 1.364-1.452m-.355 5.945a.75.75 0 1 0-1.5.058l.347 9a.75.75 0 1 0 1.499-.058zm5.48.058a.75.75 0 1 0-1.498-.058l-.347 9a.75.75 0 0 0 1.5.058z"/>
                            </Viewbox>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </Popup>

        <Border x:Name="WhiteboardBackground"
                Background="#2E5C4A"
                IsVisible="False"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ZIndex="100"/>
        
        <local:InkCanvas x:Name="InkCanvasOverlay" 
                         HorizontalAlignment="Stretch" 
                         VerticalAlignment="Stretch" 
                         IsHitTestVisible="False"
                         ZIndex="150"/>

        <Border x:Name="BottomToolbar" 
                Background="Transparent"
                Padding="20,12"
                VerticalAlignment="Bottom"
                ZIndex="200">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧按钮组 -->
                <Border x:Name="LeftButtonGroup"
                        Grid.Column="0"
                        Background="{DynamicResource ThemeSurface}" 
                        Opacity="0.8"
                        CornerRadius="{DynamicResource ThemeButtonGroupCornerRadius}"
                        Padding="{DynamicResource ThemeButtonGroupPadding}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left">
                    <Grid>
                        <!-- 普通模式左侧按钮 -->
                        <StackPanel x:Name="NormalBottomButtons"
                                    Orientation="Horizontal" 
                                    Spacing="0">
                            <Button x:Name="MoreButton" 
                                    Classes="tool-btn-square"
                                    Width="56"
                                    Height="56"
                                    Click="MoreButton_Click">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Viewbox Grid.Row="0" Width="28" Height="28" HorizontalAlignment="Center">
                                        <Path Classes="icon-path" Data="M4 6a1 1 0 0 1 1-1h14a1 1 0 1 1 0 2H5a1 1 0 0 1-1-1m0 12a1 1 0 0 1 1-1h14a1 1 0 1 1 0 2H5a1 1 0 0 1-1-1m1-7a1 1 0 1 0 0 2h8a1 1 0 1 0 0-2z"/>
                                    </Viewbox>
                                    <TextBlock Grid.Row="1" Text="更多" FontSize="10" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Center" Margin="0,4,0,0" Classes="button-text-label"/>
                                </Grid>
                            </Button>
                            
                            <Button x:Name="PictureInPictureBtn"
                                    Classes="tool-btn-square"
                                    Width="56"
                                    Height="56"
                                    Click="PictureInPicture_Click">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Viewbox Grid.Row="0" Width="28" Height="28" HorizontalAlignment="Center">
                                        <Path Classes="icon-path" Data="m15.989 4l-1.503 1.5H5.25l-.144.006A1.75 1.75 0 0 0 3.5 7.25v2.24l2.61-1.64a2.25 2.25 0 0 1 3.008.569l.095.139a2.25 2.25 0 0 1 .163 2.082l-.079.166l-1.208 2.286a.75.75 0 0 0 .933 1.05l.098-.046l1.76-.993a.75.75 0 0 1 .826 1.247l-.085.057l-1.765.996a2.25 2.25 0 0 1-3.163-2.867l.07-.145l1.208-2.286a.75.75 0 0 0-.964-1.037l-.098.052L3.5 11.262v5.493c0 .966.784 1.75 1.75 1.75h13.5a1.75 1.75 0 0 0 1.75-1.75V9.443L22 7.946v8.809a3.25 3.25 0 0 1-3.25 3.25H5.25A3.25 3.25 0 0 1 2 16.755V7.25a3.25 3.25 0 0 1 3.066-3.245L5.25 4zm5.186-.455l.13.12l.121.13a2.27 2.27 0 0 1-.121 3.08l-4.281 4.273a2.25 2.25 0 0 1-.943.562l-2.327.7a1 1 0 0 1-1.24-1.265l.739-2.295c.11-.34.299-.65.552-.903l4.29-4.283a2.27 2.27 0 0 1 3.08-.12m-2.02 1.18l-4.29 4.284a.75.75 0 0 0-.184.3l-.447 1.39l1.416-.425a.75.75 0 0 0 .314-.188l4.28-4.273l.075-.086a.769.769 0 0 0-1.163-1.002"/>
                                    </Viewbox>
                                    <TextBlock Grid.Row="1" Text="版中版" FontSize="10" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Center" Margin="0,4,0,0" Classes="button-text-label"/>
                                </Grid>
                            </Button>
                            
                            <Button Classes="tool-btn-square"
                                    Width="56"
                                    Height="56"
                                    Click="Minimize_Click">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Viewbox Grid.Row="0" Width="28" Height="28" HorizontalAlignment="Center">
                                        <Path Classes="icon-path" Data="M18 3.25H6A2.75 2.75 0 0 0 3.25 6v6a.75.75 0 0 0 1.5 0V6A1.25 1.25 0 0 1 6 4.75h12A1.25 1.25 0 0 1 19.25 6v12A1.25 1.25 0 0 1 18 19.25h-6a.75.75 0 0 0 0 1.5h6A2.75 2.75 0 0 0 20.75 18V6A2.75 2.75 0 0 0 18 3.25M11.21 13.19a.8.8 0 0 0 .29.06h4a.75.75 0 0 0 0-1.5h-2.19l3.22-3.22a.75.75 0 0 0-1.06-1.06l-3.22 3.22V8.5a.75.75 0 0 0-1.5 0v4a.8.8 0 0 0 .06.29a.7.7 0 0 0 .4.4M8 14.25H5A1.76 1.76 0 0 0 3.25 16v3A1.76 1.76 0 0 0 5 20.75h3A1.76 1.76 0 0 0 9.75 19v-3A1.76 1.76 0 0 0 8 14.25M8.25 19a.25.25 0 0 1-.25.25H5a.25.25 0 0 1-.25-.25v-3a.25.25 0 0 1 .25-.25h3a.25.25 0 0 1 .25.25Z"/>
                                    </Viewbox>
                                    <TextBlock Grid.Row="1" Text="最小化" FontSize="10" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Center" Margin="0,4,0,0" Classes="button-text-label"/>
                                </Grid>
                            </Button>
                        </StackPanel>
                        
                        <!-- 白板模式左侧按钮 -->
                        <StackPanel x:Name="WhiteboardModeButtons"
                                    Orientation="Horizontal" 
                                    Spacing="0"
                                    IsVisible="False">
                            <Button x:Name="ExitWhiteboardBtn" 
                                    Classes="tool-btn-square"
                                    Width="56"
                                    Height="56"
                                    Click="ExitWhiteboard_Click">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Viewbox Grid.Row="0" Width="28" Height="28" HorizontalAlignment="Center">
                                        <Path Classes="icon-path" Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
                                    </Viewbox>
                                    <TextBlock Grid.Row="1" Text="收起" FontSize="10" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Center" Margin="0,4,0,0" Classes="button-text-label"/>
                                </Grid>
                            </Button>
                            
                            <Button Classes="tool-btn-square"
                                    Width="56"
                                    Height="56"
                                    Click="Minimize_Click">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Viewbox Grid.Row="0" Width="28" Height="28" HorizontalAlignment="Center">
                                        <Path Classes="icon-path" Data="M6 12h12v2H6z"/>
                                    </Viewbox>
                                    <TextBlock Grid.Row="1" Text="最小化" FontSize="10" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Center" Margin="0,4,0,0" Classes="button-text-label"/>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 梯形校正模式左侧按钮组 -->
                <Border x:Name="KeystoneButtonGroup"
                        Grid.Column="0"
                        Background="{DynamicResource ThemeSurface}" 
                        Opacity="0.8"
                        CornerRadius="{DynamicResource ThemeButtonGroupCornerRadius}"
                        Padding="{DynamicResource ThemeButtonGroupPadding}"
                        VerticalAlignment="Center"
                        IsVisible="False">
                    <StackPanel x:Name="KeystoneCorrectionButtons"
                                Orientation="Horizontal" 
                                Spacing="0">
                        <Button Classes="tool-btn-square"
                                Width="56"
                                Height="56"
                                Click="ConfirmKeystone_Click">
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Viewbox Grid.Row="0" Width="28" Height="28" HorizontalAlignment="Center">
                                    <Path Fill="#4CAF50" Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                                </Viewbox>
                                <TextBlock Grid.Row="1" Text="确定" FontSize="10" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Center" Margin="0,4,0,0" Classes="button-text-label"/>
                            </Grid>
                        </Button>
                        <Button Classes="tool-btn-square"
                                Width="56"
                                Height="56"
                                Click="CancelKeystone_Click">
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Viewbox Grid.Row="0" Width="28" Height="28" HorizontalAlignment="Center">
                                    <Path Fill="#F44336" Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
                                </Viewbox>
                                <TextBlock Grid.Row="1" Text="取消" FontSize="10" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Center" Margin="0,4,0,0" Classes="button-text-label"/>
                            </Grid>
                        </Button>
                        <Button Classes="tool-btn-square"
                                Width="56"
                                Height="56"
                                Click="ResetKeystone_Click">
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Viewbox Grid.Row="0" Width="28" Height="28" HorizontalAlignment="Center">
                                    <Path Fill="#FFC107" Data="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"/>
                                </Viewbox>
                                <TextBlock Grid.Row="1" Text="重置" FontSize="10" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Center" Margin="0,4,0,0" Classes="button-text-label"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- 中央按钮组 -->
                <Border x:Name="CenterButtonGroup"
                        Grid.Column="1" 
                        Background="{DynamicResource ThemeSurface}" 
                        Opacity="0.8"
                        CornerRadius="{DynamicResource ThemeButtonGroupCornerRadius}"
                        Padding="{DynamicResource ThemeButtonGroupPadding}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid>
                        <Border x:Name="ToolSliderBackground"
                                Width="{DynamicResource ThemeSliderIndicatorSize}"
                                Height="{DynamicResource ThemeSliderIndicatorSize}"
                                Background="#0078D4"
                                CornerRadius="{DynamicResource ThemeSliderIndicatorCornerRadius}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                            <Border.RenderTransform>
                                <TranslateTransform X="0"/>
                            </Border.RenderTransform>
                        </Border>
                        <StackPanel Orientation="Horizontal" Spacing="0">
                            <ToggleButton x:Name="MoveBtn" 
                                          Classes="tool-btn-transparent"
                                          Width="56"
                                          Height="56"
                                          IsChecked="True"
                                          Click="MoveBtn_Click">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Viewbox Grid.Row="0" Width="28" Height="28" HorizontalAlignment="Center">
                                        <Path Classes="icon-path" Data="M302.189 329.126H196.105l55.831 135.993c3.889 9.428-.555 19.999-9.444 23.999l-49.165 21.427c-9.165 4-19.443-.571-23.332-9.714l-53.053-129.136l-86.664 89.138C18.729 472.71 0 463.554 0 447.977V18.299C0 1.899 19.921-6.096 30.277 5.443l284.412 292.542c11.472 11.179 3.007 31.141-12.5 31.141"/>
                                    </Viewbox>
                                    <TextBlock Grid.Row="1" Text="移动" FontSize="10" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Center" Margin="0,4,0,0" Classes="button-text-label"/>
                                </Grid>
                            </ToggleButton>
                            
                            <ToggleButton x:Name="PenBtn" 
                                          Classes="tool-btn-transparent"
                                          Width="56"
                                          Height="56"
                                          Click="PenBtn_Click">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Viewbox Grid.Row="0" Width="28" Height="28" HorizontalAlignment="Center">
                                        <Path Classes="icon-path" Data="M4.2 20.975q-.525.125-.913-.262t-.262-.913l.875-4.25l4.55 4.55zm5.875-2.1l-4.95-4.95L15.45 3.6q.575-.575 1.425-.575T18.3 3.6l2.1 2.1q.575.575.575 1.425T20.4 8.55z"/>
                                    </Viewbox>
                                    <TextBlock Grid.Row="1" Text="画笔" FontSize="10" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Center" Margin="0,4,0,0" Classes="button-text-label"/>
                                </Grid>
                            </ToggleButton>
                            
                            <ToggleButton x:Name="EraserBtn" 
                                          Classes="tool-btn-transparent"
                                          Width="56"
                                          Height="56"
                                          Click="EraserBtn_Click">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Viewbox Grid.Row="0" Width="28" Height="28" HorizontalAlignment="Center">
                                        <Path Classes="icon-path" Data="M3.121 17.85a3 3 0 0 1 0-4.243l7.071-7.072l8.486 8.486l-3.243 3.242H20a1 1 0 1 1 0 2H6.778a3 3 0 0 1-2.121-.878L3.12 17.849zm16.97-4.243l1.415-1.415a3 3 0 0 0 0-4.242l-4.243-4.243a3 3 0 0 0-4.242 0l-1.414 1.414z"/>
                                    </Viewbox>
                                    <TextBlock Grid.Row="1" Text="橡皮擦" FontSize="10" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Center" Margin="0,4,0,0" Classes="button-text-label"/>
                                </Grid>
                            </ToggleButton>

                            <Border Width="1" Background="{DynamicResource ThemeSurfaceVariant}" Margin="4,8"/>

                            <Button Classes="tool-btn-square"
                                    Width="56"
                                    Height="56"
                                    Click="UndoInk_Click">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Viewbox Grid.Row="0" Width="28" Height="28" HorizontalAlignment="Center">
                                        <Path Classes="icon-path" Data="M16 3C12 3 8.4 4.8 6 7.7V4H4v8h8v-2H6.8c2-3 5.3-5 9.2-5c6.1 0 11 4.9 11 11s-4.9 11-11 11S5 22.1 5 16H3c0 7.2 5.8 13 13 13s13-5.8 13-13S23.2 3 16 3"/>
                                    </Viewbox>
                                    <TextBlock Grid.Row="1" Text="撤销" FontSize="10" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Center" Margin="0,4,0,0" Classes="button-text-label"/>
                                </Grid>
                            </Button>
                            
                            <Button Classes="tool-btn-square"
                                    Width="56"
                                    Height="56"
                                    Click="ClearInk_Click">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Viewbox Grid.Row="0" Width="28" Height="28" HorizontalAlignment="Center">
                                        <Path Classes="icon-path" Data="M7 4a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2h4a1 1 0 1 1 0 2h-1.069l-.867 12.142A2 2 0 0 1 17.069 22H6.93a2 2 0 0 1-1.995-1.858L4.07 8H3a1 1 0 1 1 0-2h4zm2 2h6V4H9zM6.074 8l.857 12H17.07l.857-12zM10 10a1 1 0 0 1 1 1v6a1 1 0 0 1-2 0v-6a1 1 0 0 1 1-1m4 0a1 1 0 0 1 1 1v6a1 1 0 0 1-2 0v-6a1 1 0 0 1 1-1"/>
                                    </Viewbox>
                                    <TextBlock Grid.Row="1" Text="清屏" FontSize="10" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Center" Margin="0,4,0,0" Classes="button-text-label"/>
                                </Grid>
                            </Button>

                            <Border Width="1" Background="{DynamicResource ThemeSurfaceVariant}" Margin="4,8"/>

                            <Button x:Name="CaptureBtn"
                                    Classes="tool-btn-square"
                                    Width="56"
                                    Height="56"
                                    Click="Capture_Click">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Viewbox Grid.Row="0" Width="28" Height="28" HorizontalAlignment="Center">
                                        <Path Classes="icon-path" Data="M19 6.5h-1.28l-.32-1a3 3 0 0 0-2.84-2H9.44A3 3 0 0 0 6.6 5.55l-.32 1H5a3 3 0 0 0-3 3v8a3 3 0 0 0 3 3h14a3 3 0 0 0 3-3v-8a3 3 0 0 0-3-3.05m1 11a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-8a1 1 0 0 1 1-1h2a1 1 0 0 0 1-.68l.54-1.64a1 1 0 0 1 .95-.68h5.12a1 1 0 0 1 .95.68l.54 1.64a1 1 0 0 0 .9.68h2a1 1 0 0 1 1 1Zm-8-9a4 4 0 1 0 4 4a4 4 0 0 0-4-4m0 6a2 2 0 1 1 2-2a2 2 0 0 1-2 2"/>
                                    </Viewbox>
                                    <TextBlock Grid.Row="1" Text="拍照" FontSize="10" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Center" Margin="0,4,0,0" Classes="button-text-label"/>
                                </Grid>
                            </Button>
                            
                            <Button x:Name="ScanBtn"
                                    Classes="tool-btn-square"
                                    Width="56"
                                    Height="56"
                                    Click="ScanDocument_Click">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Viewbox Grid.Row="0" Width="28" Height="28" HorizontalAlignment="Center">
                                        <Path Classes="icon-path" Data="M4 22v-5h2v3h12v-3h2v5zm0-11V2h10l6 6v3h-2V9h-5V4H6v7zm-3 4v-2h22v2zm11 2"/>
                                    </Viewbox>
                                    <TextBlock Grid.Row="1" Text="扫描" FontSize="10" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Center" Margin="0,4,0,0" Classes="button-text-label"/>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 右侧按钮组 -->
                <Border x:Name="RightButtonGroup"
                        Grid.Column="2"
                        Background="{DynamicResource ThemeSurface}" 
                        Opacity="0.8"
                        CornerRadius="{DynamicResource ThemeButtonGroupCornerRadius}"
                        Padding="{DynamicResource ThemeButtonGroupPadding}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right">
                    <Grid>
                        <!-- 普通模式右侧按钮 -->
                        <StackPanel x:Name="NormalRightButtons"
                                    Orientation="Horizontal" 
                                    Spacing="0">
                            <Button x:Name="TogglePhotoBtn"
                                    Classes="tool-btn-square"
                                    Width="56"
                                    Height="56"
                                    Click="TogglePhotoPanel_Click">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Viewbox Grid.Row="0" Width="28" Height="28" HorizontalAlignment="Center">
                                        <Path Classes="icon-path" Data="M19 4H5a3 3 0 0 0-3 3v10a3 3 0 0 0 3 3h14a3 3 0 0 0 3-3V7a3 3 0 0 0-3-3M5 18a1 1 0 0 1-1-1v-2.42l3.3-3.29a1 1 0 0 1 1.4 0L15.41 18Zm15-1a1 1 0 0 1-1 1h-.77l-3.81-3.83l.88-.88a1 1 0 0 1 1.4 0l3.3 3.29Zm0-3.24l-1.88-1.87a3.06 3.06 0 0 0-4.24 0l-.88.88l-2.88-2.88a3.06 3.06 0 0 0-4.24 0L4 11.76V7a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1Z"/>
                                    </Viewbox>
                                    <TextBlock Grid.Row="1" Text="照片" FontSize="10" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Center" Margin="0,4,0,0" Classes="button-text-label"/>
                                </Grid>
                            </Button>
                            
                            <Button x:Name="ConnectDeviceBtn"
                                    Classes="tool-btn-square"
                                    Width="56"
                                    Height="56"
                                    Click="ConnectDeviceBtn_Click">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Viewbox Grid.Row="0" Width="28" Height="28" HorizontalAlignment="Center">
                                        <Path Classes="icon-path" Data="M640 384v64H448a128 128 0 0 0-128 128v128a128 128 0 0 0 128 128h320a128 128 0 0 0 128-128V576a128 128 0 0 0-64-110.848V394.88c74.56 26.368 128 97.472 128 181.056v128a192 192 0 0 1-192 192H448a192 192 0 0 1-192-192V576a192 192 0 0 1 192-192zM384 640v-64h192a128 128 0 0 0 128-128V320a128 128 0 0 0-128-128H256a128 128 0 0 0-128 128v128a128 128 0 0 0 64 110.848v70.272A192.06 192.06 0 0 1 64 448V320a192 192 0 0 1 192-192h320a192 192 0 0 1 192 192v128a192 192 0 0 1-192 192z"/>
                                    </Viewbox>
                                    <TextBlock Grid.Row="1" Text="连接设备" FontSize="10" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Center" Margin="0,4,0,0" Classes="button-text-label"/>
                                </Grid>
                            </Button>
                        </StackPanel>
                        
                        <!-- 白板模式右侧按钮（翻页） -->
                        <StackPanel x:Name="WhiteboardPageButtons"
                                    Orientation="Horizontal" 
                                    Spacing="4"
                                    IsVisible="False">
                            <Button x:Name="PrevPageBtn"
                                    Classes="tool-btn-square"
                                    Width="48"
                                    Height="56"
                                    Click="PrevPage_Click">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Viewbox Grid.Row="0" Width="24" Height="24" HorizontalAlignment="Center">
                                        <Path Classes="icon-path" Data="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
                                    </Viewbox>
                                    <TextBlock Grid.Row="1" Text="上一页" FontSize="9" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Center" Margin="0,4,0,0" Classes="button-text-label"/>
                                </Grid>
                            </Button>
                            
                            <Border x:Name="PageInfoBorder"
                                    Width="70"
                                    Height="56"
                                    Background="Transparent"
                                    VerticalAlignment="Center"
                                    Cursor="Hand"
                                    PointerPressed="PageInfoBorder_PointerPressed">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock x:Name="PageInfoText" 
                                               Text="1/1" 
                                               FontSize="18" 
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource ThemeTextPrimary}" 
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            
                            <Button x:Name="NextPageBtn"
                                    Classes="tool-btn-square"
                                    Width="48"
                                    Height="56"
                                    Click="NextPage_Click">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Viewbox Grid.Row="0" Width="24" Height="24" HorizontalAlignment="Center">
                                        <Path x:Name="NextPagePath" Classes="icon-path" Data="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
                                    </Viewbox>
                                    <TextBlock x:Name="NextPageText" Grid.Row="1" Text="下一页" FontSize="9" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Center" Margin="0,4,0,0" Classes="button-text-label"/>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>