                    </Canvas>

                    <Canvas x:Name="ElemHydro" Width="50" Height="50">
                        <Path x:Name="HydroFill" Width="50" Height="50"
                              Fill="#4CC7F7"
                              Stretch="Uniform"
                              Data="M984.4,552.4c2.9,1.2,5.8,2.1,8.5,3.5c37.9,19.7,78.3,29.4,120.9,32.1c81.2,5.1,147.5-56.9,146.8-138c-0.6-64.8-51.2-121.5-115.9-130.7c-19.6-2.8-38.6-1.6-57.4,3.9c-9.2,2.7-18.6,4.6-27.7,0.5c-12.1-5.5-19.1-15.1-20.1-28.6c-1-13.5,3.9-24.8,16.1-30.6c10.9-5.3,22.7-9.6,34.6-12c119.6-24.1,224.2,77.3,208.5,192.4c-6.5,47.7-29.6,86-67.2,115.7c-4,3.1-8,6.1-11.2,10.8c2.4-1,4.9-1.8,7.1-3.1c64.3-38.4,98.3-95.4,101.4-169.7c4.9-115.8-85.8-192.3-163.9-205.4c-80.7-13.6-147.2,11-198.8,74.5c-15.3,18.9-33.2,23.1-51.7,11c-11.8-7.7-16.8-19.7-12.3-33.1c2.7-7.9,6.7-15.7,11.4-22.6c42.1-62,100.9-98.2,174.5-110C1200.5,95,1330.2,157,1368,298.7c38.6,144.6-57.4,272.9-183.2,304c-46.5,11.5-92.7,9.4-138.4-5.2C1021,589.3,1000.7,573.9,984.4,552.4L984.4,552.4z M1193.5,533.8c-17.7,26.7-53.3,40.8-86.5,34.3c-41.2-8.1-71.3-43.9-72.7-86.4c-1.3-39.4,27.6-77.5,67.5-87.2c30.3-7.4,58.1-1.4,82,19.3c14.3,12.3,21.7,28.4,24.6,46.6c2.1,13-2.6,24.3-11.6,33.6c-11.9,12.2-33,10.4-43.6-3.9c-4.1-5.6-6.6-12.5-9.1-19c-9-23.3-30.9-31-52.6-18.3c-29.4,17.3-35.7,53.1-14,80.2c19.6,24.5,54.5,32.7,84.8,19C1173.3,547,1183.2,539.9,1193.5,533.8L1193.5,533.8z M909.6,330.2c17.6,0,33.3,15.8,33.6,33.7c0.2,17.8-16.8,34.6-34.8,34.2c-17.7-0.3-33.4-16.2-33.4-34C874.9,345.6,890.6,330.2,909.6,330.2L909.6,330.2z M977.5,474.8c-0.2,12.9-11,23.4-23.7,23.1c-12.1-0.3-23.8-12-23.7-23.8c0.1-12.3,11.3-23.6,23.6-23.7C967.2,450.1,977.7,461,977.5,474.8L977.5,474.8z"/>
                    </Canvas>

                    <Canvas x:Name="ElemAnemo" Width="50" Height="50">
                        <Path x:Name="AnemoFill" Width="50" Height="50"
