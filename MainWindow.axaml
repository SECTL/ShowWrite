<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShowWrite"
        x:Class="ShowWrite.MainWindow"
        x:DataType="local:MainWindow"
        Title="ShowWrite"
        WindowState="FullScreen"
        Background="{DynamicResource ThemeBackground}"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        CanResize="False"
        Opened="Window_Opened"
        Closing="Window_Closing">

    <Window.Resources>
        <local:SelectedBackgroundConverter x:Key="SelectedBackgroundConverter"/>
        <local:SelectedForegroundConverter x:Key="SelectedForegroundConverter"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Path.icon-path">
            <Setter Property="Fill" Value="{DynamicResource ThemeIconColor}"/>
        </Style>
        <Style Selector="ToggleButton:checked Path.icon-path">
            <Setter Property="Fill" Value="White"/>
        </Style>
        <Style Selector="Border.no-background">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.no-background:checked">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.nav-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Button.nav-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource ThemeHoverBackground}"/>
        </Style>
        <Style Selector="Button.nav-btn:pressed">
            <Setter Property="Background" Value="{DynamicResource ThemePressedBackground}"/>
        </Style>
        <Style Selector="ToggleButton.tool-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="CornerRadius" Value="{DynamicResource ThemeButtonCornerRadius}"/>
        </Style>
        <Style Selector="ToggleButton.tool-btn:checked">
            <Setter Property="Background" Value="{DynamicResource ThemePrimary}"/>
        </Style>
        <Style Selector="ToggleButton.tool-btn-square">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="{DynamicResource ThemeButtonPadding}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="CornerRadius" Value="{DynamicResource ThemeButtonCornerRadius}"/>
        </Style>
        <Style Selector="ToggleButton.tool-btn-square:pointerover">
            <Setter Property="Background" Value="{DynamicResource ThemeHoverBackground}"/>
        </Style>
        <Style Selector="ToggleButton.tool-btn-square:pressed">
            <Setter Property="Background" Value="{DynamicResource ThemePressedBackground}"/>
        </Style>
        <Style Selector="ToggleButton.tool-btn-square:checked">
            <Setter Property="Background" Value="{DynamicResource ThemePrimary}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource ThemeButtonCornerRadius}"/>
        </Style>
        <Style Selector="ToggleButton.tool-btn-square.no-background:checked">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="{DynamicResource ThemeButtonCornerRadius}"/>
        </Style>
        <Style Selector="Button.tool-btn-square">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="{DynamicResource ThemeButtonPadding}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="CornerRadius" Value="{DynamicResource ThemeButtonCornerRadius}"/>
        </Style>
        <Style Selector="Button.tool-btn-square:pointerover">
            <Setter Property="Background" Value="{DynamicResource ThemeHoverBackground}"/>
        </Style>
        <Style Selector="Button.tool-btn-square:pressed">
            <Setter Property="Background" Value="{DynamicResource ThemePressedBackground}"/>
        </Style>
        <Style Selector="ToggleButton.tool-btn-transparent">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="{DynamicResource ThemeButtonPadding}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="CornerRadius" Value="{DynamicResource ThemeButtonCornerRadius}"/>
        </Style>
        <Style Selector="ToggleButton.tool-btn-transparent:pointerover">
            <Setter Property="Background" Value="{DynamicResource ThemeHoverBackground}"/>
        </Style>
        <Style Selector="ToggleButton.tool-btn-transparent:pressed">
            <Setter Property="Background" Value="{DynamicResource ThemePressedBackground}"/>
        </Style>
        <Style Selector="ToggleButton.tool-btn-transparent:checked">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.delete-btn">
            <Setter Property="Background" Value="{DynamicResource ThemeDanger}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.delete-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource ThemeDangerHover}"/>
        </Style>
        <Style Selector="Button.delete-btn:pressed">
            <Setter Property="Background" Value="#C62828"/>
        </Style>
        <Style Selector="CheckBox.ink-checkbox">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
        </Style>
        <Style Selector="CheckBox.ink-checkbox:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
        </Style>
        <Style Selector="CheckBox.ink-checkbox:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
        </Style>
        <Style Selector="TextBlock.button-text-label">
            <Setter Property="FontFamily" Value="avares://ShowWrite/font/HarmonyOS_Sans_SC_Medium.ttf#HarmonyOS Sans SC"/>
        </Style>
        <Style Selector="Button.nav-btn TextBlock">
            <Setter Property="FontFamily" Value="avares://ShowWrite/font/HarmonyOS_Sans_SC_Medium.ttf#HarmonyOS Sans SC"/>
        </Style>
        <Style Selector="CheckBox.ink-checkbox">
            <Setter Property="FontFamily" Value="avares://ShowWrite/font/HarmonyOS_Sans_SC_Medium.ttf#HarmonyOS Sans SC"/>
        </Style>
        <Style Selector="Button.menu-btn">
            <Setter Property="FontFamily" Value="avares://ShowWrite/font/HarmonyOS_Sans_SC_Medium.ttf#HarmonyOS Sans SC"/>
        </Style>
    </Window.Styles>

    <Grid>
        <Grid x:Name="VideoAreaContainer" 
              HorizontalAlignment="Stretch" 
              VerticalAlignment="Stretch"
              Background="{DynamicResource ThemeVideoBackground}">
            <Image x:Name="VideoImage" Stretch="None" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            
            <Canvas x:Name="KeystoneOverlayCanvas" IsVisible="False">
                <Polygon x:Name="KeystonePolygon" 
                         Fill="#30FF0000" 
                         Stroke="#FF0000" 
                         StrokeThickness="2"
                         Points="0,0 0,0 0,0 0,0"/>
                
                <Border x:Name="KeystonePointTL" 
                        Canvas.Left="0" Canvas.Top="0"
                        Width="24" Height="24"
                        CornerRadius="12"
                        Background="#FF0078D4"
                        BorderBrush="White"
                        BorderThickness="2"
                        Cursor="Hand"
                        Tag="0">
                    <TextBlock Text="1" Foreground="White" FontSize="12" FontWeight="Bold" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                
                <Border x:Name="KeystonePointTR" 
                        Canvas.Left="0" Canvas.Top="0"
                        Width="24" Height="24"
                        CornerRadius="12"
                        Background="#FF0078D4"
                        BorderBrush="White"
                        BorderThickness="2"
                        Cursor="Hand"
                        Tag="1">
                    <TextBlock Text="2" Foreground="White" FontSize="12" FontWeight="Bold" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                
                <Border x:Name="KeystonePointBR" 
                        Canvas.Left="0" Canvas.Top="0"
                        Width="24" Height="24"
                        CornerRadius="12"
                        Background="#FF0078D4"
                        BorderBrush="White"
                        BorderThickness="2"
                        Cursor="Hand"
                        Tag="2">
                    <TextBlock Text="3" Foreground="White" FontSize="12" FontWeight="Bold" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                
                <Border x:Name="KeystonePointBL" 
                        Canvas.Left="0" Canvas.Top="0"
                        Width="24" Height="24"
                        CornerRadius="12"
                        Background="#FF0078D4"
                        BorderBrush="White"
                        BorderThickness="2"
                        Cursor="Hand"
                        Tag="3">
                    <TextBlock Text="4" Foreground="White" FontSize="12" FontWeight="Bold" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Canvas>
            
            <StackPanel x:Name="LoadingContainer"
                        Orientation="Vertical"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="20"
                        IsVisible="True"
                        IsHitTestVisible="False">
                
                <TextBlock x:Name="StatusText"
                           FontSize="24"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           TextAlignment="Center">
                    <Run Text="正在扫描可用摄像头"/>
                    <LineBreak/>
                    <Run Text="请等待20秒左右" FontSize="18" Foreground="#AAAAAA"/>
                </TextBlock>

                <StackPanel x:Name="LoadingElementsPanel"
                            Orientation="Horizontal"
                            Spacing="20"
                            HorizontalAlignment="Center"
                            IsVisible="True"
                            IsHitTestVisible="False">

                    <Canvas x:Name="ElemPyro" Width="50" Height="50">
                        <Path x:Name="PyroFill" Width="50" Height="50"
                              Fill="#EF7A35"
                              Stretch="Uniform"
